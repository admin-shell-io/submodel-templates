@startuml
!theme plain
left to right direction
hide class circle
hide class methods
skinparam classAttributeIconSize 0
' skinparam linetype polyline
skinparam linetype ortho

mainframe  DocumentVersion

class "DocumentVersion" as ID00000001 <<SMC>> {
  +Language : SML
  +Version : xs:string [0..1]
  +Title : MLP
  +Subtitle : MLP [0..1]
  +Description : MLP [0..1]
  +DigitalFiles : SML
}

class "Language" as ID00000002 <<SML>> {
  +[00]  : xs:string [1..*]
}

class "DigitalFiles" as ID00000003 <<SML>> {
  +[00]  : File [1..*]
}

ID00000001 *--  ID00000002 : ""
ID00000001 *--  ID00000003 : ""
@enduml
