@startuml
!theme plain
left to right direction
hide class circle
hide class methods
skinparam classAttributeIconSize 0
' skinparam linetype polyline
skinparam linetype ortho

mainframe  NegativeEvents

class "NegativeEvents" as ID00000001 <<SML>> {
  +[00] NegativeEvent : SMC [0..*]
}

class "[00] NegativeEvent" as ID00000002 <<SMC>> {
  +NegativeEventValue : xs:string
  +LastUpdate : xs:dateTime
}

ID00000001 *--  ID00000002 : ""
@enduml
